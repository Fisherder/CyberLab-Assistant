{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cla.edu/contracts/rubric.schema.json",
  "title": "Rubric",
  "type": "object",
  "required": ["rubricVersion", "criteria"],
  "properties": {
    "rubricVersion": {"type": "string"},
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "graderType", "maxScore", "evidencePolicy"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "graderType": {
            "type": "string",
            "enum": ["DETERMINISTIC_ORACLE", "EVENT_PATTERN", "POLICY_EVENTS", "LLM_RUBRIC"]
          },
          "maxScore": {"type": "number", "minimum": 0},
          "evidencePolicy": {
            "type": "object",
            "required": ["minTrustLevel"],
            "properties": {
              "minTrustLevel": {"type": "string", "enum": ["S1", "S2", "S3", "S4"]},
              "requiredEventTypes": {"type": "array", "items": {"type": "string"}}
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}

