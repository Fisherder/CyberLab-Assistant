CLA_ENV=local
CLA_DEV_MODE=true
CLA_DATABASE_URL=postgresql+psycopg://cla:cla@localhost:5432/cla
CLA_DEV_OIDC_ISSUER=cla-dev-oidc
CLA_DEV_OIDC_AUDIENCE=cla-api
CLA_DEV_OIDC_SECRET=change-me-dev-oidc
CLA_OIDC_ISSUER=https://oidc.example.edu
CLA_OIDC_AUDIENCE=cla-api
CLA_OIDC_DISCOVERY_URL=https://oidc.example.edu/.well-known/openid-configuration
CLA_OIDC_JWKS_URL=https://oidc.example.edu/.well-known/jwks.json
CLA_OIDC_ALGORITHMS=RS256
CLA_TERMINAL_TICKET_SECRET=change-me-terminal-ticket
CLA_ORACLE_SHARED_SECRET=change-me-oracle
CLA_INTERNAL_SERVICE_TOKEN=change-me-internal
CLA_API_URL=http://localhost:8000
CLA_ORPHAN_SCAN_INTERVAL=5m
CLA_ORPHAN_GRACE_PERIOD=10m
CLA_GATEWAY_URL=ws://localhost:8081/ws/terminal
CLA_REDIS_ADDR=127.0.0.1:6379
CLA_REDIS_KEY_PREFIX=cla:terminal-gateway:replay
CLA_RECORDING_QUEUE_SIZE=1024
CLA_SESSIOND_ENDPOINT=127.0.0.1:7777
CLA_TRANSCRIPT_STORAGE_BACKEND=local
CLA_TRANSCRIPT_OBJECT_ROOT=/tmp/cla-transcript-objects
CLA_TRANSCRIPT_S3_BUCKET=cla-transcript-raw
CLA_TRANSCRIPT_S3_PREFIX=terminal-transcripts
CLA_TRANSCRIPT_S3_ENDPOINT_URL=http://localhost:9000
CLA_TRANSCRIPT_S3_REGION=us-east-1
CLA_TRANSCRIPT_S3_FORCE_PATH_STYLE=true
CLA_TRANSCRIPT_ENCRYPTION_KEY=change-me-transcript-key
CLA_AGENT_RUNTIME_ENABLED=false
CLA_REMOTE_DESKTOP_ENABLED=false
CLA_SIMULATED_WORKSPACE_ENABLED=false
