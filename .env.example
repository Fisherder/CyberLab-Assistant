CLA_ENV=local
CLA_DEV_MODE=true
CLA_DATABASE_URL=postgresql+psycopg://cla:cla@localhost:5432/cla
CLA_DEV_OIDC_ISSUER=cla-dev-oidc
CLA_DEV_OIDC_AUDIENCE=cla-api
CLA_DEV_OIDC_SECRET=replace-with-dev-oidc-secret
CLA_OIDC_ISSUER=https://oidc.example.edu
CLA_OIDC_AUDIENCE=cla-api
CLA_OIDC_DISCOVERY_URL=https://oidc.example.edu/.well-known/openid-configuration
CLA_OIDC_JWKS_URL=https://oidc.example.edu/.well-known/jwks.json
CLA_OIDC_ALGORITHMS=RS256
CLA_TERMINAL_TICKET_SECRET=replace-with-terminal-ticket-secret
CLA_ORACLE_SHARED_SECRET=replace-with-oracle-secret
CLA_INTERNAL_SERVICE_TOKEN=replace-with-internal-service-token
CLA_API_URL=http://localhost:8000
CLA_ORPHAN_SCAN_INTERVAL=5m
CLA_ORPHAN_GRACE_PERIOD=10m
CLA_GATEWAY_URL=ws://localhost:8081/ws/terminal
CLA_LOCAL_TARGET_BASE_URL=http://127.0.0.1:18080
CLA_REDIS_ADDR=127.0.0.1:6379
CLA_REDIS_KEY_PREFIX=cla:terminal-gateway:replay
CLA_RECORDING_QUEUE_SIZE=1024
CLA_SESSIOND_ENDPOINT=127.0.0.1:7777
CLA_TRANSCRIPT_STORAGE_BACKEND=local
CLA_TRANSCRIPT_OBJECT_ROOT=/tmp/cla-transcript-objects
CLA_TRANSCRIPT_S3_BUCKET=cla-transcript-raw
CLA_TRANSCRIPT_S3_PREFIX=terminal-transcripts
CLA_TRANSCRIPT_S3_ENDPOINT_URL=http://localhost:9000
CLA_TRANSCRIPT_S3_REGION=us-east-1
CLA_TRANSCRIPT_S3_FORCE_PATH_STYLE=true
CLA_TRANSCRIPT_ENCRYPTION_KEY=replace-with-transcript-encryption-key
CLA_AGENT_RUNTIME_ENABLED=true
CLA_MODEL_PROVIDER=openai-compatible
CLA_MODEL_BASE_URL=https://api.deepseek.com
CLA_MODEL_NAME=deepseek-v4-flash
CLA_MODEL_API_KEY=replace-with-your-model-api-key
CLA_MODEL_TIMEOUT_SECONDS=30
CLA_MODEL_MAX_TOKENS=1200
CLA_MODEL_TEMPERATURE=0
CLA_CHALLENGE_ARTIFACT_STORAGE_BACKEND=local
CLA_CHALLENGE_ARTIFACT_OBJECT_ROOT=/tmp/cla-challenge-artifacts
CLA_CHALLENGE_ARTIFACT_S3_BUCKET=cla-challenge-artifacts
CLA_CHALLENGE_ARTIFACT_S3_PREFIX=challenge-artifacts
CLA_CHALLENGE_ARTIFACT_S3_ENDPOINT_URL=http://localhost:9000
CLA_CHALLENGE_ARTIFACT_S3_REGION=us-east-1
CLA_CHALLENGE_ARTIFACT_S3_FORCE_PATH_STYLE=true
CLA_REMOTE_DESKTOP_ENABLED=false
CLA_SIMULATED_WORKSPACE_ENABLED=false
